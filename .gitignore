.env.local
.env.production.local
.env.development.local

# ── Build Output ─────────────────────────
dist/
build/

# ── Logs ─────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── Vite Cache ───────────────────────────
.vite/

# ── OS / Editor ──────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
